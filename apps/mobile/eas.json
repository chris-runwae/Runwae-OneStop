{
  "cli": {
    "version": ">= 14.0.2",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_VARIANT": "development",
        "RNAsyncStorage_useSystemSQLite": "1",
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "preview",
      "env": {
        "APP_VARIANT": "preview",
        "RNAsyncStorage_useSystemSQLite": "1",
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN"
      },
      "ios": {
        "simulator": false
      },
      "cache": {
        "disabled": true
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_VARIANT": "production",
        "RNAsyncStorage_useSystemSQLite": "1",
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "tech@runwae.io",
        "ascAppId": "6765879787",
        "appleTeamId": "5WJR695A8F"
      }
    },
    "preview": {
      "ios": {
        "appleId": "tech@runwae.io",
        "ascAppId": "6765879787",
        "appleTeamId": "5WJR695A8F"
      }
    }
  }
}
