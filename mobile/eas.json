{
  "cli": {
    "version": ">= 14.0.2",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "env": { "APP_VARIANT": "development" },
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "env": { "APP_VARIANT": "preview" },
      "distribution": "store",
      "ios": {
        "simulator": false
      },
      "cache": {
        "disabled": true
      },
      "channel": "preview"
    },
    "production": {
      "env": { "APP_VARIANT": "production" },
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "chrisobocha@gmail.com",
        "ascAppId": "6754623801",
        "appleTeamId": "VSC85SPZ2A"
      }
    },
    "preview": {
      "ios": {
        "appleId": "chrisobocha@gmail.com",
        "ascAppId": "6754623801",
        "appleTeamId": "VSC85SPZ2A"
      }
    }
  }
}