{
  "cli": {
    "version": ">= 14.0.2",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_VARIANT": "development"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "preview",
      "env": {
        "APP_VARIANT": "preview"
      },
      "ios": {
        "simulator": false
      },
      "cache": {
        "disabled": true
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_VARIANT": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "chrisobocha@gmail.com",
        "ascAppId": "6765879787",
        "appleTeamId": "5WJR695A8F"
      }
    },
    "preview": {
      "ios": {
        "appleId": "chrisobocha@gmail.com",
        "ascAppId": "6765879787",
        "appleTeamId": "5WJR695A8F"
      }
    }
  }
}
